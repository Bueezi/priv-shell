{
    "layer": "bottom",
    "position": "top",
    "height": 5,
    "spacing": 0,
    "modules-left": ["hyprland/workspaces", "hyprland/submap"],
    "modules-center": ["custom/clock"],
    "modules-right": ["pulseaudio", "battery", "backlight", "tray"],
    "hyprland/workspaces": {
        "disable-scroll": true,
        "format": "{icon}{name}",
        "format-icons": {
            "default": " ",
            "urgent": "!",
            "active": "*"
        }
    },
    "hyprland/submap": {
        "format": "  {}"
    },
    "custom/clock": {
        "format": "<span color='#252525'>[ </span>{text}<span color='#252525'> ]</span>",
        "exec": "date +'%H:%M %A, %b %d' | awk '{print tolower($0)}'",
        "interval": 3
    },
    "pulseaudio": {
        "format": "<span color='#afa193'><b>vol:</b></span> {volume}%",
        "format-muted": "<span color='#afa193'><b>vol:</b></span> {volume}% (m)"
    },
    "battery": {
        "format": "<span color='#252525'> / </span><span color='#afa193'><b>bat:</b></span> {capacity}%",
        "format-charging": "<span color='#252525'> / </span><span color='#afa193'><b>ac:</b></span> {capacity}%",
        "tooltip": false,
        "interval": 20
    },
    "backlight": {
        "format": "<span color='#252525'> / </span><span color='#afa193'><b>bl:</b></span> {percent}%<span color='#252525'> ]</span>",
        "tooltip": false
    },
    "tray": {
        "icon-size": 20,
        "spacing": 7,
        "tooltip": false
    }
}
